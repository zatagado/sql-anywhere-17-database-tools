{
    "name": "sql-anywhere-17-database-tools",
    "publisher": "sql-anywhere-17-database-tools",
    "displayName": "SQL Anywhere 17 Database Tools",
    "description": "",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.109.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "sql-anywhere-17-database-tools.namasteworld",
                "title": "Vue Web View"
            },
            {
                "command": "databaseTree.addDatasource",
                "title": "Add Datasource"
            },
            {
                "command": "databaseTree.removeDatasource",
                "title": "Remove Datasource"
            },
            {
                "command": "databaseTree.refresh",
                "title": "Refresh",
                "icon": {
                    "light": "resources/light/refresh.svg",
                    "dark": "resources/dark/refresh.svg"
                }
            },
            {
                "command": "sql-anywhere-17-database-tools.edit",
                "title": "Edit",
                "icon": {
                    "light": "resources/light/edit.svg",
                    "dark": "resources/dark/edit.svg"
                }
            },
            {
                "command": "sql-anywhere-17-database-tools.openVirtualDocument",
                "title": "Open Virtual Document"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "sql-anywhere-17-database-tools.edit",
                    "when": "editorLangId == sql",
                    "group": "navigation"
                }
            ],
            "view/title": [
                {
                    "command": "databaseTree.addDatasource",
                    "when": "view == databaseTree"
                },
                {
                    "command": "databaseTree.refresh",
                    "when": "view == databaseTree",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "databaseTree.removeDatasource",
                    "when": "view == databaseTree && viewItem == databaseTreeItem"
                }
            ]
        },
        "views": {
            "database-tools": [
                {
                    "id": "databaseTree",
                    "name": "Datasources",
                    "icon": "media/dep.svg",
                    "contextualTitle": "Datasources"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "database-tools",
                    "title": "Database Tools",
                    "icon": "media/datasources.svg"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "databaseTree",
                "contents": "No datasources added. Add a datasource to get started."
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "yarn run package",
        "compile": "yarn run check-types && yarn run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "yarn run check-types && yarn run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.109.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.3",
        "eslint": "^9.39.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "odbc": "^2.4.9"
    }
}
