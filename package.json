{
    "name": "sql-anywhere-17-database-tools",
    "publisher": "sql-anywhere-17-database-tools",
    "displayName": "SQL Anywhere 17 Database Tools",
    "description": "",
    "version": "0.1.4",
    "engines": {
        "vscode": "^1.105.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "sql-anywhere-17-database-tools.datasource.addDatasource",
                "title": "Add Datasource"
            },
            {
                "command": "sql-anywhere-17-database-tools.datasource.removeDatasource",
                "title": "Remove Datasource"
            },
            {
                "command": "_sql-anywhere-17-database-tools.databaseTree.removeDatasource",
                "title": "Remove Datasource"
            },
            {
                "command": "_sql-anywhere-17-database-tools.databaseTree.refresh",
                "title": "Refresh",
                "icon": {
                    "light": "resources/light/refresh.svg",
                    "dark": "resources/dark/refresh.svg"
                }
            },
            {
                "command": "_sql-anywhere-17-database-tools.databaseTree.select",
                "title": "Select"
            },
            {
                "command": "sql-anywhere-17-database-tools.results.execute",
                "title": "Tasks: Execute SQL",
                "icon": {
                    "light": "resources/light/execute.svg",
                    "dark": "resources/dark/execute.svg"
                }
            },
            {
                "command": "sql-anywhere-17-database-tools.results.executeWithDatasource",
                "title": "Tasks: Execute SQL with Datasource",
                "icon": {
                    "light": "resources/light/execute.svg",
                    "dark": "resources/dark/execute.svg"
                }
            },
            {
                "command": "_sql-anywhere-17-database-tools.results",
                "title": "Open Results Webview"
            },
            {
                "command": "_sql-anywhere-17-database-tools.preview.openVirtualDocument",
                "title": "Open Virtual Document"
            },
            {
                "command": "sql-anywhere-17-database-tools.search",
                "title": "Search: Datasource",
                "shortTitle": "Search Datasource"
            },
            {
                "command": "sql-anywhere-17-database-tools.newScratchSqlFile",
                "title": "File: New Scratch SQL File..."
            }
        ],
        "configuration": {
            "type": "object",
            "title": "SQL Anywhere 17 Database Tools",
            "properties": {
                "sql-anywhere-17-database-tools.connection.usePooling": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use connection pooling for the database. Disabling this is recommended for databases with short connection timeouts."
                },
                "sql-anywhere-17-database-tools.results.fetchSize": {
                    "type": "number",
                    "default": 500,
                    "minimum": 1,
                    "description": "Number of rows to fetch when executing a query."
                }
            }
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "_sql-anywhere-17-database-tools.databaseTree.refresh",
                    "when": "false"
                },
                {
                    "command": "_sql-anywhere-17-database-tools.databaseTree.removeDatasource",
                    "when": "false"
                },
                {
                    "command": "_sql-anywhere-17-database-tools.databaseTree.select",
                    "when": "false"
                },
                {
                    "command": "_sql-anywhere-17-database-tools.preview.openVirtualDocument",
                    "when": "false"
                },
                {
                    "command": "_sql-anywhere-17-database-tools.results",
                    "when": "false"
                }
            ],
            "editor/title": [
                {
                    "command": "sql-anywhere-17-database-tools.results.execute",
                    "alt": "sql-anywhere-17-database-tools.results.executeWithDatasource",
                    "when": "editorLangId == sql && !editorReadonly",
                    "group": "navigation"
                }
            ],
            "view/title": [
                {
                    "command": "sql-anywhere-17-database-tools.datasource.addDatasource",
                    "when": "view == databaseTreeStandalone || view == databaseTreeExplorer"
                },
                {
                    "command": "sql-anywhere-17-database-tools.search",
                    "when": "view == databaseTreeStandalone || view == databaseTreeExplorer"
                },
                {
                    "command": "_sql-anywhere-17-database-tools.databaseTree.refresh",
                    "when": "view == databaseTreeStandalone || view == databaseTreeExplorer",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "_sql-anywhere-17-database-tools.databaseTree.removeDatasource",
                    "when": "(view == databaseTreeStandalone || view == databaseTreeExplorer) && viewItem == databaseItem"
                },
                {
                    "command": "_sql-anywhere-17-database-tools.databaseTree.select",
                    "when": "(view == databaseTreeStandalone || view == databaseTreeExplorer) && (viewItem == tableObjectItem || viewItem == viewObjectItem)",
                    "group": "navigation"
                }
            ]
        },
        "views": {
            "database-tools": [
                {
                    "id": "databaseTreeStandalone",
                    "name": "Datasources",
                    "icon": "$(database)",
                    "contextualTitle": "Datasources"
                }
            ],
            "explorer": [
                {
                    "id": "databaseTreeExplorer",
                    "name": "Datasources"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "database-tools",
                    "title": "Database Tools",
                    "icon": "$(database)"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "databaseTree",
                "contents": "No datasources added. Add a datasource to get started."
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "yarn run build:web && yarn run package",
        "compile": "yarn run check-types && yarn run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "yarn run check-types && yarn run lint && node esbuild.js --production",
        "build:web": "yarn --cwd web run build-only",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.105.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.27.3",
        "eslint": "^9.39.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "odbc": "^2.4.9"
    }
}
